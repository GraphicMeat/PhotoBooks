    "NSPhotoLibraryUsageDescription": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks lays out books from photos you choose in your library. Originals stay in Photos; the app only reads them to arrange pages and export your book."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks gestaltet BГјcher aus Fotos, die du in deiner Mediathek auswГӨhlst. Die Originale bleiben in Fotos; die App liest sie nur, um Seiten zu gestalten und dein Buch zu exportieren."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks compose des livres Г  partir des photos que vous choisissez dans votre photothГЁque. Les originaux restent dans Photos ; l'app ne fait que les lire pour organiser les pages et exporter votre livre."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks compone libros a partir de las fotos que eliges en tu biblioteca. Los originales permanecen en Fotos; la app solo los lee para organizar las pГЎginas y exportar tu libro."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks compone libri con le foto che scegli nella tua libreria. Gli originali restano in Foto; l'app li legge soltanto per organizzare le pagine ed esportare il tuo libro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooksгҒҜгҖҒгғ©гӮӨгғ–гғ©гғӘгҒӢгӮүйҒёгӮ“гҒ еҶҷзңҹгҒ§гғ–гғғгӮҜгӮ’дҪңжҲҗгҒ—гҒҫгҒҷгҖӮгӮӘгғӘгӮёгғҠгғ«гҒҜеҶҷзңҹгӮўгғ—гғӘгҒ«дҝқеӯҳгҒ•гӮҢгҒҹгҒҫгҒҫгҒ§гҖҒгӮўгғ—гғӘгҒҜгғҡгғјгӮёгҒ®ж§ӢжҲҗгҒЁгғ–гғғгӮҜгҒ®жӣёгҒҚеҮәгҒ—гҒ®гҒҹгӮҒгҒ«иӘӯгҒҝеҸ–гӮӢгҒ гҒ‘гҒ§гҒҷгҖӮ"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooksлҠ” лқјмқҙлёҢлҹ¬лҰ¬м—җм„ң м„ нғқн•ң мӮ¬м§„мңјлЎң мұ…мқ„ кө¬м„ұн•©лӢҲлӢӨ. мӣҗліёмқҖ мӮ¬м§„ м•ұм—җ к·ёлҢҖлЎң мң м§Җлҗҳл©°, м•ұмқҖ нҺҳмқҙм§ҖлҘј кө¬м„ұн•ҳкі  мұ…мқ„ лӮҙліҙлӮҙкё° мң„н•ҙм„ңл§Ң мқҪм–ҙмҳөлӢҲлӢӨ."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks дјҡдҪҝз”ЁдҪ еңЁз…§зүҮеӣҫеә“дёӯйҖүжӢ©зҡ„з…§зүҮжқҘжҺ’зүҲеӣҫд№ҰгҖӮеҺҹеӣҫд»Қдҝқз•ҷеңЁвҖңз…§зүҮвҖқдёӯпјӣжң¬еә”з”Ёд»…иҜ»еҸ–е®ғд»¬д»Ҙзј–жҺ’йЎөйқўе№¶еҜјеҮәдҪ зҡ„еӣҫд№ҰгҖӮ"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O PhotoBooks monta livros a partir das fotos que vocГӘ escolhe na sua biblioteca. Os originais permanecem no Fotos; o app apenas os lГӘ para organizar as pГЎginas e exportar seu livro."
          }
        }
      }
    },
