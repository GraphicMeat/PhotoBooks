{
  "sourceLanguage": "en",
  "strings": {
    "Choose the moments you love. We’ll arrange them into a polished book you can refine and print.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Choose the moments you love. We’ll arrange them into a polished book you can refine and print."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wähle die Momente, die du liebst. Wir arrangieren sie zu einem fertigen Buch, das du verfeinern und drucken kannst."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Choisissez les moments que vous aimez. Nous les organiserons en un livre soigné que vous pourrez peaufiner et imprimer."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Elige los momentos que más te gustan. Los organizaremos en un libro pulido que podrás perfeccionar e imprimir."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Scegli i momenti che ami. Li organizzeremo in un libro curato che potrai perfezionare e stampare."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "大切な瞬間を選んでください。洗練されたブックにまとめ、仕上げて印刷できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "좋아하는 순간들을 선택하세요. 다듬고 인쇄할 수 있는 완성도 높은 책으로 구성해 드립니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "选择你喜爱的瞬间，我们会将它们编排成一本精美的图书，供你完善和打印。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Escolha os momentos que você ama. Vamos organizá-los em um livro impecável que você pode refinar e imprimir."
          }
        }
      }
    },
