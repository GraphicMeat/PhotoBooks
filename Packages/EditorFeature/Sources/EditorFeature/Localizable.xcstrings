    "Whole page is locked — click to unlock so reflow can re-lay it" : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Die gesamte Seite ist gesperrt – klicke, um sie zu entsperren, damit der Neufluss sie neu anordnen kann"
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Whole page is locked — click to unlock so reflow can re-lay it"
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Toda la página está bloqueada: haz clic para desbloquearla y permitir que la reorganización la vuelva a componer"
          }
        },
        "fr" : {
          "stringUnit" : {
