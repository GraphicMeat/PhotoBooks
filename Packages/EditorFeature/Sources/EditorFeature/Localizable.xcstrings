    "These include photos left out of the original selection. Select a frame to use one." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dazu gehören Fotos, die bei der ursprünglichen Auswahl nicht berücksichtigt wurden. Wähle einen Rahmen aus, um eines davon zu verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These include photos left out of the original selection. Select a frame to use one."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Esto incluye fotos que quedaron fuera de la selección original. Selecciona un marco para usar una."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Cela inclut les photos écartées de la sélection d'origine. Sélectionnez un cadre pour en utiliser une."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Comprendono le foto escluse dalla selezione originale. Seleziona un riquadro per usarne una."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これには元の選択から外れた写真も含まれます。フレームを選択して使用してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "여기에는 원래 선택에서 제외된 사진도 포함됩니다. 프레임을 선택하여 사용하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Isso inclui fotos que ficaram fora da seleção original. Selecione um quadro para usar uma delas."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "其中包括原始选择中未包含的照片。选择一个画框即可使用。"
          }
        }
      }
    },
    "These photos can't be found. Pick the folder they moved to, or remove them from the book." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Diese Fotos können nicht gefunden werden. Wähle den Ordner, in den sie verschoben wurden, oder entferne sie aus dem Buch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "These photos can't be found. Pick the folder they moved to, or remove them from the book."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "No se pueden encontrar estas fotos. Elige la carpeta a la que se movieron o quítalas del libro."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ces photos sont introuvables. Choisissez le dossier vers lequel elles ont été déplacées, ou retirez-les du livre."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Queste foto non sono state trovate. Scegli la cartella in cui sono state spostate oppure rimuovile dal libro."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "これらの写真が見つかりません。移動先のフォルダを選ぶか、ブックから削除してください。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "이 사진을 찾을 수 없습니다. 이동된 폴더를 선택하거나 포토북에서 제거하세요."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Não é possível encontrar essas fotos. Escolha a pasta para a qual foram movidas ou remova-as do livro."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "找不到这些照片。请选择它们移动到的文件夹，或将其从相册中移除。"
          }
        }
      }
    },
    "This changes only the workspace behind the book." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Dies ändert nur die Arbeitsfläche hinter dem Buch."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "This changes only the workspace behind the book."
          }
        },
        "es" : {
          "stringUnit" : {
