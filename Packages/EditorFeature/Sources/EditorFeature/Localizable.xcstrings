    "Drag to position. Double-click to zoom in or out; pinch or use + / − for finer control." : {
      "localizations" : {
        "de" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ziehen, um zu positionieren. Doppelklicken zum Ein- oder Auszoomen; für feinere Kontrolle zusammenziehen/spreizen oder + / − verwenden."
          }
        },
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Drag to position. Double-click to zoom in or out; pinch or use + / − for finer control."
          }
        },
        "es" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arrastra para posicionar. Haz doble clic para acercar o alejar el zoom; pellizca o usa + / − para un control más preciso."
          }
        },
        "fr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Faites glisser pour positionner. Double-cliquez pour zoomer ou dézoomer ; pincez ou utilisez + / − pour un contrôle plus précis."
          }
        },
        "it" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Trascina per posizionare. Fai doppio clic per aumentare o ridurre lo zoom; usa il pizzico o + / − per un controllo più preciso."
          }
        },
        "ja" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "ドラッグして位置を調整します。ダブルクリックでズームイン・アウト。ピンチ操作または+/−でより細かく調整できます。"
          }
        },
        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "드래그하여 위치를 조정하세요. 더블 클릭으로 확대/축소하고, 핀치 동작이나 +/−로 더 세밀하게 조정할 수 있습니다."
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Arraste para posicionar. Dê um clique duplo para aproximar ou afastar o zoom; belisque ou use + / − para um controle mais preciso."
          }
        },
        "zh-Hans" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "拖动以调整位置。双击可放大或缩小；捏合手势或使用 + / − 进行更精细的调整。"
          }
        }
      }
    },
