        "ko" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "페이지 전체가 잠겨 있습니다 — 클릭하여 잠금을 해제하면 재배치 시 다시 구성할 수 있습니다"
          }
        },
        "pt-BR" : {
          "stringUnit" : {
            "state" : "translated",
