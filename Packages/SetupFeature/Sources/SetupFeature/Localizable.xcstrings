    "Switching to a different shape relays out unlocked pages; locked pages and the cover keep their layout and get a review badge.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Der Wechsel zu einer anderen Form gestaltet nicht gesperrte Seiten neu; gesperrte Seiten und das Cover behalten ihr Layout und erhalten ein Prüfabzeichen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Switching to a different shape relays out unlocked pages; locked pages and the cover keep their layout and get a review badge."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Cambiar a otra forma vuelve a diseñar las páginas no bloqueadas; las páginas bloqueadas y la portada mantienen su diseño y reciben una insignia de revisión."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Passer à une autre forme remet en page les pages non verrouillées ; les pages verrouillées et la couverture conservent leur mise en page et reçoivent un badge à vérifier."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Il passaggio a una forma diversa reimpagina le pagine non bloccate; le pagine bloccate e la copertina mantengono il loro layout e ricevono un badge di revisione."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "別の形に切り替えると、ロックされていないページは再レイアウトされます。ロックされたページと表紙はレイアウトを保持し、確認バッジが表示されます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "다른 모양으로 전환하면 잠기지 않은 페이지는 다시 레이아웃됩니다. 잠긴 페이지와 표지는 레이아웃을 유지하며 검토 배지가 표시됩니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Mudar para um formato diferente reorganiza as páginas não bloqueadas; as páginas bloqueadas e a capa mantêm o layout e recebem um selo de revisão."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "切换为其他形状会重新排版未锁定的页面;已锁定的页面和封面会保留原有排版,并显示一个待复核标记。"
          }
        }
      }
    },
