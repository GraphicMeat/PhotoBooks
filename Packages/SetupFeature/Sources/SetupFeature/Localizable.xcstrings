    "PhotoBooks lays out books from photos you pick in your library. Access is currently denied — you can grant it in Settings, or build your book from a folder instead.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks gestaltet Bücher aus Fotos, die du in deiner Mediathek auswählst. Der Zugriff ist derzeit verweigert — du kannst ihn in den Einstellungen gewähren oder dein Buch stattdessen aus einem Ordner erstellen."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks lays out books from photos you pick in your library. Access is currently denied — you can grant it in Settings, or build your book from a folder instead."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks diseña libros a partir de las fotos que eliges en tu biblioteca. El acceso está actualmente denegado; puedes concederlo en Ajustes, o crear tu libro desde una carpeta en su lugar."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks met en page des livres à partir des photos que vous choisissez dans votre photothèque. L'accès est actuellement refusé — vous pouvez l'autoriser dans les Réglages, ou créer votre livre à partir d'un dossier à la place."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks impagina i libri a partire dalle foto che scegli nella tua libreria. L'accesso è attualmente negato: puoi concederlo in Impostazioni, oppure creare il tuo libro da una cartella."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooksは、ライブラリから選んだ写真でブックをレイアウトします。現在アクセスが拒否されています。設定で許可するか、代わりにフォルダからブックを作成できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks는 보관함에서 선택한 사진으로 북을 구성합니다. 현재 접근이 거부되어 있습니다 — 설정에서 권한을 허용하거나, 대신 폴더에서 북을 만들 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O PhotoBooks monta livros a partir das fotos que você escolhe na sua biblioteca. O acesso está atualmente negado — você pode concedê-lo em Ajustes ou criar seu livro a partir de uma pasta."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "PhotoBooks 会使用你在资料库中选择的照片排版图书。当前访问权限被拒绝——你可以在“设置”中授予权限,或改为从文件夹创建图书。"
          }
        }
      }
    },
