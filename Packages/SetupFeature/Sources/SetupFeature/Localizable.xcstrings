    "Analyze on-device and keep a balanced selection of about %lld photos": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Analysiere auf dem Gerät und behalte eine ausgewogene Auswahl von etwa %lld Fotos"
