    "We found %lld photos. Pick a starting point; you can review every choice before creating the book.": {
      "localizations": {
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Wir haben %lld Fotos gefunden. Wähle einen Ausgangspunkt; du kannst jede Auswahl überprüfen, bevor das Buch erstellt wird."
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "We found %lld photos. Pick a starting point; you can review every choice before creating the book."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontramos %lld fotos. Elige un punto de partida; podrás revisar cada elección antes de crear el libro."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Nous avons trouvé %lld photos. Choisissez un point de départ ; vous pourrez revoir chaque choix avant de créer le livre."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Abbiamo trovato %lld foto. Scegli un punto di partenza; potrai rivedere ogni scelta prima di creare il libro."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld枚の写真が見つかりました。開始地点を選んでください。ブックを作成する前に、すべての選択内容を確認できます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "사진 %lld장을 찾았습니다. 시작점을 선택하세요. 북을 만들기 전에 모든 선택을 검토할 수 있습니다."
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Encontramos %lld fotos. Escolha um ponto de partida; você poderá revisar cada escolha antes de criar o livro."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "我们找到了 %lld 张照片。选择一个起点;在创建图书之前,你可以查看每一项选择。"
          }
        }
      }
    },
