{
  "sourceLanguage": "en",
  "strings": {
    "A print-ready PDF with bleed for generic print services.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A print-ready PDF with bleed for generic print services."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein druckfertiges PDF mit Beschnitt für allgemeine Druckdienste."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF prêt à imprimer avec fond perdu pour les services d'impression courants."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF listo para imprimir con sangrado para servicios de impresión genéricos."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF pronto per la stampa con abbondanza per servizi di stampa generici."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "汎用の印刷サービス向けに裁ち落とし付きの印刷用PDFです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "일반 인쇄 서비스용으로 도련이 포함된 인쇄용 PDF입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适用于通用印刷服务的带出血印刷级 PDF。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um PDF pronto para impressão com sangria para serviços de impressão genéricos."
          }
        }
      }
    },
    "A screen-resolution PDF for sharing and on-device viewing.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "A screen-resolution PDF for sharing and on-device viewing."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Ein PDF in Bildschirmauflösung zum Teilen und Anzeigen auf Geräten."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF en résolution écran pour le partage et la visualisation sur appareil."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF en resolución de pantalla para compartir y ver en el dispositivo."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Un PDF a risoluzione schermo per la condivisione e la visualizzazione sul dispositivo."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "共有やデバイスでの閲覧向けの画面解像度PDFです。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "공유 및 기기에서 보기에 적합한 화면 해상도 PDF입니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "适合分享和设备端查看的屏幕分辨率 PDF。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Um PDF em resolução de tela para compartilhar e visualizar no dispositivo."
          }
        }
      }
    },
    "Add %lld blank pages": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add %lld blank pages"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld leere Seiten hinzufügen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter %lld pages vierges"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añadir %lld páginas en blanco"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi %lld pagine vuote"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "空白ページを%lld枚追加"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "빈 페이지 %lld개 추가"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加 %lld 个空白页"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar %lld páginas em branco"
          }
        }
      }
    },
    "Append blank pages to meet the minimum page count": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Append blank pages to meet the minimum page count"
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Leere Seiten anhängen, um die Mindestseitenzahl zu erreichen"
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Ajouter des pages vierges pour atteindre le nombre minimal de pages"
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Añadir páginas en blanco para alcanzar el número mínimo de páginas"
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Aggiungi pagine vuote per raggiungere il numero minimo di pagine"
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "最小ページ数を満たすために空白ページを追加します"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "최소 페이지 수를 맞추기 위해 빈 페이지를 추가합니다"
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "添加空白页以满足最少页数要求"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "Adicionar páginas em branco para atingir o número mínimo de páginas"
          }
        }
      }
    },
    "Blurb needs two files. Pick a folder; PhotoBooks writes “%@” and “%@” into it.": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb needs two files. Pick a folder; PhotoBooks writes “%@” and “%@” into it."
          }
        },
        "de": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb benötigt zwei Dateien. Wähle einen Ordner; PhotoBooks schreibt „%@“ und „%@“ hinein."
          }
        },
        "fr": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb a besoin de deux fichiers. Choisissez un dossier ; PhotoBooks y écrira « %@ » et « %@ »."
          }
        },
        "es": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb necesita dos archivos. Elige una carpeta; PhotoBooks escribirá “%@” y “%@” en ella."
          }
        },
        "it": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb richiede due file. Scegli una cartella; PhotoBooks vi scriverà “%@” e “%@”."
          }
        },
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurbには2つのファイルが必要です。フォルダを選んでください。PhotoBooksがそこに「%@」と「%@」を書き込みます。"
          }
        },
        "ko": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb에는 파일 2개가 필요합니다. 폴더를 선택하면 PhotoBooks가 그 안에 “%@”와 “%@”를 씁니다."
          }
        },
        "zh-Hans": {
          "stringUnit": {
            "state": "translated",
            "value": "Blurb 需要两个文件。请选择一个文件夹；PhotoBooks 会将“%@”和“%@”写入其中。"
          }
        },
        "pt-BR": {
          "stringUnit": {
            "state": "translated",
            "value": "O Blurb precisa de dois arquivos. Escolha uma pasta; o PhotoBooks grava “%@” e “%@” nela."
          }
        }
      }
    },
